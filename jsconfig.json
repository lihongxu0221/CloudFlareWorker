{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "typeRoots": ["./types"]
  },
  "include": ["*.js", "types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
